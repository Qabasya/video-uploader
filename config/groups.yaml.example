# Маппинг учебных групп: точное имя подпапки в VIDEO_ROOT (кириллица допустима) →
# slug для ключей S3 + блок lms с произвольными ID для плагина fs-lms.
#
# Скопируйте в groups.yaml и заполните реальными группами (список должен быть
# согласован с video-groups.csv на Windows-стороне).
# Файл валидируется при старте сервиса; ошибка схемы — падение с внятным сообщением.
# Папка без записи здесь пропускается (skipped_unmapped) с событием GroupUnmapped.
#
# slug: уникален, формат ^[a-z0-9]+(-[a-z0-9]+)*$ — попадает в ключи S3.
# lms:  обязательный непустой плоский словарь; ключи ^[a-z0-9_]+$,
#       значения — int или ASCII-строка. Сервис семантику не интерпретирует:
#       блок как есть уходит в манифест, REST-payload и x-amz-meta-lms-*.
#       Состав полей определяет плагин; новые поля — без изменений кода.
#
# Подпапка VIDEO_ROOT — это либо папка учебной группы (групповые занятия),
# либо персональная папка преподавателя (индивидуальные занятия). Сервис их
# не различает — семантику задаёт состав lms-блока на стороне плагина:
#   - есть group_id  → групповая ветка (видео крепится к занятию группы
#                       по дате/времени recorded_at);
#   - только teacher_username, без group_id → индивидуальная ветка
#                       (занятие kind='individual' этого преподавателя).
# teacher_username = WP user_login = sAMAccountName в домене.
groups:
  "КЕГЭ-1":                    # папка группы — групповые занятия
    slug: kege-1
    lms:
      group_id: 3
      course_id: 42
      teacher_id: 7
  "ОГЭ-1":
    slug: oge-1
    lms:
      group_id: 4
      course_id: 43
      teacher_id: 7
  "Индивидуальные-Петров":     # персональная папка препода — индивидуальные занятия
    slug: ind-petrov
    lms:
      teacher_username: "i.petrov"
