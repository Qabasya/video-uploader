# Конфигурация fs-video-uploader. Скопируйте в .env и заполните секреты.
# Секреты — только через env/.env; .env не коммитится (в .gitignore).

# --- Шара и данные ---
# Корень смонтированной SMB-шары (подпапка = учебная группа)
VIDEO_ROOT=/mnt/video
# Каталог сервиса: state.db и логи
DATA_DIR=/data
# Маппинг групп (см. config/groups.yaml.example)
GROUPS_FILE=/app/config/groups.yaml

# --- Сканирование ---
# Период опроса шары, секунды
SCAN_INTERVAL_SECONDS=300
# Файл считается дописанным, если size/mtime не менялись столько минут
STABILITY_MINUTES=5
# Расширения-кандидаты (через запятую)
ALLOWED_EXTENSIONS=.webm,.mp4,.mkv
# Regex с именованными группами day/month/year/hour/minute/second.
# Пусто = встроенный default под записи Телемоста (блок ДД_ММ_ГГ_ЧЧ_ММ_СС в имени).
DATE_REGEX=
# Пропускать файлы старше N дней (пусто = выключено)
SKIP_OLDER_THAN_DAYS=

# --- Архивация ---
# Перемещать исходник в архивную подпапку после регистрации (файлы никогда не удаляются)
ARCHIVE_AFTER_REGISTER=true
# Имя архивной подпапки внутри папки группы
ARCHIVE_SUBDIR=_uploaded

# --- Обработка ---
# Максимум попыток на файл, затем событие VideoFailed
MAX_ATTEMPTS=5
# Часовой пояс для recorded_at
TZ_NAME=Europe/Kaliningrad
# Сухой прогон: шаги с внешними побочными эффектами (S3, LMS, архивация)
# подменяются заглушками в composition root
DRY_RUN=false
# При DRY_RUN=true — регистрировать видео в LMS по-настоящему (реальный HTTP+HMAC),
# S3 и архивация остаются заглушками. Для проверки матчинга занятия без реальной
# загрузки видео. Без эффекта при DRY_RUN=false (LMS и так настоящий).
DRY_RUN_LMS_LIVE=false

# --- S3 (Beget) ---
S3_ENDPOINT_URL=https://s3.ru1.storage.beget.cloud
S3_REGION=ru-1
# Имя бакета выдаёт Beget (с префиксом вида f6bcd57c2800-...), в коде не хардкодится
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=
# Префикс ключей
S3_KEY_PREFIX=videos

# --- LMS (fs-lms) ---
# Например: http://11.11.11.20:8080
LMS_BASE_URL=
# Секрет HMAC-подписи запросов (= FS_LMS_VIDEO_HMAC_SECRET в wp-config плагина)
LMS_HMAC_SECRET=

# --- Наблюдаемость (опционально) ---
# Grafana Loki push API; пусто = выключено
LOKI_URL=
# Telegram для логов ERROR+ и бизнес-уведомлений; пусто = выключено
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- HTTP API ---
API_PORT=8090

# Период "сервис жив" в лог/Loki (сводка реестра), секунды. Не завязан на SCAN_INTERVAL_SECONDS —
# не спамит на каждый цикл сканирования.
HEARTBEAT_INTERVAL_SECONDS=3600
